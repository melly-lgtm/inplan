{
  "name": "@inplan/renderer",
  "version": "0.0.0",
  "private": true,
  "description": "inplan's browser-safe React editor (preview + CodeMirror source + comments + diff review). Hosted by the Electron app and the web edition over the same Api seam.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": ["dist", "src/styles.css"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@inplan/core": "0.0.0",
    "codemirror": "^6.0.1",
    "markdown-it": "^14.1.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0"
  }
}
